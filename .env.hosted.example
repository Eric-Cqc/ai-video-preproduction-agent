APP_ENVIRONMENT=hosted
PILOT_DOMAIN=pilot.example.com
API_BASE_URL=https://pilot.example.com/api
PUBLIC_API_BASE_URL=https://pilot.example.com/api
API_ALLOWED_CORS_ORIGINS=https://pilot.example.com
POSTGRES_DB=pilot
POSTGRES_USER=pilot
POSTGRES_PASSWORD=REPLACE_WITH_A_LONG_RANDOM_PASSWORD
MODEL_PROVIDER=deepseek
DEEPSEEK_API_KEY=REPLACE_WITH_DEEPSEEK_SERVER_KEY
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_TIMEOUT_SECONDS=60
DEEPSEEK_MAX_ATTEMPTS=2
DEEPSEEK_MAX_INPUT_BYTES=131072
DEEPSEEK_MAX_OUTPUT_BYTES=262144
API_MAX_REQUEST_BYTES=262144
API_MAX_UPLOAD_BYTES=104857600
SOURCE_OBJECT_STORAGE_ADAPTER=local_filesystem_v1
SOURCE_OBJECT_STORAGE_ROOT=/var/lib/ai-video-preproduction/source-objects
PILOT_ACCESS_PASSWORD=REPLACE_WITH_A_LONG_RANDOM_PILOT_PASSWORD
PILOT_SESSION_SECRET=REPLACE_WITH_A_32_CHARACTER_MINIMUM_RANDOM_SECRET
PILOT_SESSION_TTL_SECONDS=28800
PILOT_ORGANIZATION_ID=11111111-1111-1111-1111-111111111111
PILOT_WORKSPACE_ID=22222222-2222-2222-2222-222222222222
PILOT_ACTOR_SUBJECT=pilot:owner
PILOT_ORGANIZATION_SLUG=pilot
PILOT_ORGANIZATION_NAME=Private Pilot
PILOT_WORKSPACE_SLUG=production
PILOT_WORKSPACE_NAME=Production
