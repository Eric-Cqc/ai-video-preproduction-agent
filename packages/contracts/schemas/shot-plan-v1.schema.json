{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://ai-video-preproduction-agent.local/contracts/shot-plan-v1.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "shots"],
  "properties": {
    "schema_version": { "const": "1.0.0" },
    "shots": {
      "type": "array",
      "minItems": 1,
      "maxItems": 180,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "shot_number",
          "storyboard_scene_number",
          "source_script_scene_number",
          "shot_type",
          "framing",
          "camera_angle",
          "camera_movement",
          "subject",
          "action",
          "environment",
          "lighting",
          "visual_style",
          "estimated_duration_seconds",
          "voiceover_segment",
          "dialogue_segment",
          "on_screen_text",
          "transition_in",
          "transition_out",
          "continuity_requirements",
          "production_notes",
          "generation_prompt",
          "negative_prompt",
          "safety_notes"
        ],
        "properties": {
          "shot_number": { "type": "integer", "minimum": 1, "maximum": 180 },
          "storyboard_scene_number": {
            "type": "integer",
            "minimum": 1,
            "maximum": 60
          },
          "source_script_scene_number": {
            "type": "integer",
            "minimum": 1,
            "maximum": 60
          },
          "shot_type": { "type": "string", "maxLength": 80 },
          "framing": { "type": "string", "maxLength": 120 },
          "camera_angle": { "type": "string", "maxLength": 120 },
          "camera_movement": { "type": "string", "maxLength": 120 },
          "subject": { "type": "string", "maxLength": 500 },
          "action": { "type": "string", "maxLength": 1000 },
          "environment": { "type": "string", "maxLength": 500 },
          "lighting": { "type": "string", "maxLength": 300 },
          "visual_style": { "type": "string", "maxLength": 300 },
          "estimated_duration_seconds": {
            "type": "integer",
            "minimum": 1,
            "maximum": 60
          },
          "voiceover_segment": { "type": "string", "maxLength": 1000 },
          "dialogue_segment": { "type": "string", "maxLength": 1000 },
          "on_screen_text": { "type": "string", "maxLength": 500 },
          "transition_in": { "type": "string", "maxLength": 200 },
          "transition_out": { "type": "string", "maxLength": 200 },
          "continuity_requirements": {
            "type": "array",
            "maxItems": 12,
            "items": { "type": "string", "maxLength": 300 }
          },
          "production_notes": {
            "type": "array",
            "maxItems": 12,
            "items": { "type": "string", "maxLength": 300 }
          },
          "generation_prompt": {
            "type": "string",
            "minLength": 1,
            "maxLength": 2000,
            "pattern": "^[^\\u0000-\\u001f]*$"
          },
          "negative_prompt": {
            "type": "string",
            "maxLength": 1000,
            "pattern": "^[^\\u0000-\\u001f]*$"
          },
          "safety_notes": {
            "type": "array",
            "maxItems": 12,
            "items": { "type": "string", "maxLength": 300 }
          }
        }
      }
    }
  }
}
