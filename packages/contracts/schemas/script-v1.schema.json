{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://ai-video-preproduction-agent.local/contracts/script-v1.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "title",
    "logline",
    "target_duration_seconds",
    "language",
    "format",
    "sections",
    "scenes",
    "voiceover",
    "dialogue",
    "on_screen_text",
    "music_direction",
    "sound_direction",
    "call_to_action",
    "compliance_notes",
    "unresolved_assumptions"
  ],
  "properties": {
    "schema_version": { "const": "1.0.0" },
    "title": { "type": "string", "minLength": 1, "maxLength": 160 },
    "logline": { "type": "string", "minLength": 1, "maxLength": 500 },
    "target_duration_seconds": {
      "type": "integer",
      "minimum": 1,
      "maximum": 600
    },
    "language": { "type": "string", "minLength": 2, "maxLength": 20 },
    "format": { "type": "string", "minLength": 1, "maxLength": 80 },
    "sections": {
      "type": "array",
      "maxItems": 20,
      "items": { "type": "string", "minLength": 1, "maxLength": 500 }
    },
    "scenes": {
      "type": "array",
      "minItems": 1,
      "maxItems": 60,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "scene_number",
          "purpose",
          "estimated_duration_seconds",
          "setting",
          "action",
          "voiceover",
          "dialogue",
          "on_screen_text",
          "transition"
        ],
        "properties": {
          "scene_number": { "type": "integer", "minimum": 1, "maximum": 60 },
          "purpose": { "type": "string", "minLength": 1, "maxLength": 500 },
          "estimated_duration_seconds": {
            "type": "integer",
            "minimum": 1,
            "maximum": 120
          },
          "setting": { "type": "string", "maxLength": 300 },
          "action": { "type": "string", "maxLength": 1000 },
          "voiceover": { "type": "string", "maxLength": 1000 },
          "dialogue": { "type": "string", "maxLength": 1000 },
          "on_screen_text": { "type": "string", "maxLength": 500 },
          "transition": { "type": "string", "maxLength": 200 }
        }
      }
    },
    "voiceover": { "type": "string", "maxLength": 8000 },
    "dialogue": { "type": "string", "maxLength": 8000 },
    "on_screen_text": {
      "type": "array",
      "maxItems": 60,
      "items": { "type": "string", "maxLength": 500 }
    },
    "music_direction": { "type": "string", "maxLength": 1000 },
    "sound_direction": { "type": "string", "maxLength": 1000 },
    "call_to_action": { "type": "string", "maxLength": 500 },
    "compliance_notes": {
      "type": "array",
      "maxItems": 20,
      "items": { "type": "string", "maxLength": 500 }
    },
    "unresolved_assumptions": {
      "type": "array",
      "maxItems": 20,
      "items": { "type": "string", "maxLength": 500 }
    }
  }
}
